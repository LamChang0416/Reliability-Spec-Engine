{
  "DC 1: General schedule (一般寄送)": {
    "Schedule A - Handling (人工搬運跌落)": {
      "Drop Test (跌落測試)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬人工搬運與包裹上下貨時的摔落。分為三次不同高度層級的跌落，確保邊角與面受到衝擊。",
          "Description_EN": "Manual handling drop tests. Drop height is determined by package weight and assurance level.",
          "Drop Sequence": "One corner, one edge, then remaining faces."
        },
        "tests": [
          {"Weight": "0 - 9.1 kg (0 - 20 lb)", "Level I Height": "610 mm (24 in)", "Level II Height": "381 mm (15 in)", "Level III Height": "229 mm (9 in)"},
          {"Weight": "9.1 - 18.1 kg (20 - 40 lb)", "Level I Height": "533 mm (21 in)", "Level II Height": "330 mm (13 in)", "Level III Height": "229 mm (9 in)"},
          {"Weight": "18.1 - 27.2 kg (40 - 60 lb)", "Level I Height": "457 mm (18 in)", "Level II Height": "305 mm (12 in)", "Level III Height": "229 mm (9 in)"},
          {"Weight": "27.2 - 45.4 kg (60 - 100 lb)", "Level I Height": "381 mm (15 in)", "Level II Height": "229 mm (9 in)", "Level III Height": "178 mm (7 in)"},
          {"Weight": "Over 45.4 kg (Over 100 lb)", "Level I Height": "305 mm (12 in)", "Level II Height": "229 mm (9 in)", "Level III Height": "178 mm (7 in)"}
        ]
      }
    },
    "Schedule C - Vehicle Vibration (車輛振動)": {
      "Random Vibration - Truck (卡車隨機振動 PSD)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬公路卡車運輸的隨機振動光譜 (PSD)。工程師可直接輸入此斷點矩陣至振動機台連線軟體。",
          "Description_EN": "Highway truck transport random vibration PSD profiles. Levels define test severity.",
          "Test Duration": "180 minutes typical (or specific to DC routing)",
          "Assurance Level I": "0.73 Grms (Highest Severity, High Value/Custom)",
          "Assurance Level II": "0.52 Grms (Average Severity, Default)",
          "Assurance Level III": "0.37 Grms (Lowest Severity)"
        },
        "tests": [
          {"Frequency (Hz)": "1.0", "Level I (g²/Hz)": "0.0001", "Level II (g²/Hz)": "0.00005", "Level III (g²/Hz)": "0.000025"},
          {"Frequency (Hz)": "4.0", "Level I (g²/Hz)": "0.02", "Level II (g²/Hz)": "0.01", "Level III (g²/Hz)": "0.005"},
          {"Frequency (Hz)": "16.0", "Level I (g²/Hz)": "0.02", "Level II (g²/Hz)": "0.01", "Level III (g²/Hz)": "0.005"},
          {"Frequency (Hz)": "40.0", "Level I (g²/Hz)": "0.002", "Level II (g²/Hz)": "0.001", "Level III (g²/Hz)": "0.0005"},
          {"Frequency (Hz)": "80.0", "Level I (g²/Hz)": "0.002", "Level II (g²/Hz)": "0.001", "Level III (g²/Hz)": "0.0005"},
          {"Frequency (Hz)": "200.0", "Level I (g²/Hz)": "0.00002", "Level II (g²/Hz)": "0.00001", "Level III (g²/Hz)": "0.000005"}
        ]
      },
      "Random Vibration - Air (空運隨機振動 PSD)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬飛機貨艙的隨機振動光譜。空運的頻率較高、整體 Grms 能量更強。",
          "Description_EN": "Air transport random vibration PSD profiles. High frequency focus.",
          "Test Duration": "120 minutes typical",
          "Assurance Level I": "1.49 Grms",
          "Assurance Level II": "1.05 Grms",
          "Assurance Level III": "0.74 Grms"
        },
        "tests": [
          {"Frequency (Hz)": "2.0", "Level I (g²/Hz)": "0.0004", "Level II (g²/Hz)": "0.0002", "Level III (g²/Hz)": "0.0001"},
          {"Frequency (Hz)": "12.0", "Level I (g²/Hz)": "0.02", "Level II (g²/Hz)": "0.01", "Level III (g²/Hz)": "0.005"},
          {"Frequency (Hz)": "100.0", "Level I (g²/Hz)": "0.02", "Level II (g²/Hz)": "0.01", "Level III (g²/Hz)": "0.005"},
          {"Frequency (Hz)": "300.0", "Level I (g²/Hz)": "0.00002", "Level II (g²/Hz)": "0.00001", "Level III (g²/Hz)": "0.000005"}
        ]
      }
    },
    "Schedule D - Stacked Vibration (推疊振動)": {
      "Vibration under Compressive Load (帶載振動)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬底層包裹在運輸途中承受上方貨物重量時的動態振動破壞力。",
          "Description_EN": "Simulates dynamic bottom-load compression during vehicle vibration.",
          "Top Load Formula": "L = W * ((H-h)/h) * F",
          "Variables": "W: Package weight, H: Stack height, h: Package height"
        },
        "tests": [
          {"Assurance Level": "I", "Safety Factor (F)": "1.0", "Vibration Profile": "Use Level I PSD"},
          {"Assurance Level": "II", "Safety Factor (F)": "0.7", "Vibration Profile": "Use Level II PSD"},
          {"Assurance Level": "III", "Safety Factor (F)": "0.5", "Vibration Profile": "Use Level III PSD"}
        ]
      }
    },
    "Schedule C/D - Compression (堆碼抗壓公式計算)": {
      "Machine Apply and Release/Hold (抗壓機壓放試驗)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "驗證紙箱與包裝材長時間堆疊在外箱上的靜態抗壓強度。使用公式計算目標下壓力 (Load)。",
          "Description_EN": "Static compression strength evaluation using a testing machine.",
          "Compression Formula": "Load (L) = W * ((H-h)/h) * F",
          "W": "Weight of one package",
          "H": "Maximum stacking height in transit or storage",
          "h": "Height of one package"
        },
        "tests": [
          {"Assurance Level & Material": "Level I - Corrugated Box", "Safety Factor (F)": "8.0", "Application": "Highest severity storage"},
          {"Assurance Level & Material": "Level II - Corrugated Box", "Safety Factor (F)": "4.5", "Application": "Standard transit warehouse stacking"},
          {"Assurance Level & Material": "Level III - Corrugated Box", "Safety Factor (F)": "3.0", "Application": "Short term or low risk stacking"}
        ]
      }
    }
  },
  "DC 3: Single package environment (單一小包裹環境)": {
    "Schedule A - Handling (人工落摔)": {
      "Drop Test (跌落測試)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬單獨寄送的包裹摔落機率較高，適用於電商或零售單件出貨。",
          "Description_EN": "Single parcel drop simulation, commonly used for retail shipments."
        },
        "tests": [
          {"Hazard": "Manual Handling", "Action": "Same drops as defined in General Schedule A but typically tested at Level I or II"}
        ]
      }
    },
    "Schedule I - Low Pressure (低氣壓/空運)": {
      "Altitude Simulation (高海拔模擬)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "模擬飛機貨艙未加壓環境，驗證密封袋、液體瓶罐是否會破裂或滲漏。",
          "Description_EN": "Un-pressurized cargo hold simulation checking for seal failure.",
          "Test Pressure": "Usually equivalent to 10,000 to 15,000 ft altitude",
          "Duration": "60 minutes"
        },
        "tests": [
          {"Requirement": "Maintain test pressure", "Action": "Monitor for ballooning, leakage, or burst"}
        ]
      }
    }
  },
  "DC 13: Air and motor freight (空運與公路混合)": {
    "Schedule A, C, F, I (綜合排程)": {
      "Air Delivery Profile (空運物流連貫測試)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "最常見的外銷空運測試循環，包含跌落、空運隨機振動、卡車隨機振動與低壓測試的組合拳。",
          "Description_EN": "Standard sequence for international air freight including drops, air vib, truck vib, and altitude."
        },
        "tests": [
          {"Sequence": "1. Schedule A", "Action": "Handling Drops (First half)"},
          {"Sequence": "2. Schedule C", "Action": "Truck Random Vibration (e.g. Level II, 60 mins)"},
          {"Sequence": "3. Schedule I", "Action": "Low Pressure (Altitude)"},
          {"Sequence": "4. Schedule C", "Action": "Air Random Vibration (e.g. Level II, 120 mins)"},
          {"Sequence": "5. Schedule A", "Action": "Handling Drops (Second half on different faces)"}
        ]
      }
    }
  }
}