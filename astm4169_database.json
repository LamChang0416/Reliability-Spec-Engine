  "Schedule F - Loose Load Vibration (鬆散負載震動)": {
    "Repetitive Shock (重複性衝擊)": {
      "Loose Load Transportation": {
        "parameters": {
          "Description": "模擬散裝貨物在運輸過程中的彈跳與碰撞 [cite: 317]",
          "Dwell Time Distribution": "50% along normal vertical shipping axis, 50% evenly along all other possible orientations [cite: 321]"
        },
        "tests": [
          {"Assurance Level": "Level I", "Dwell Time": "60 min [cite: 338, 339]"},
          {"Assurance Level": "Level II", "Dwell Time": "40 min [cite: 338, 339]"},
          {"Assurance Level": "Level III", "Dwell Time": "30 min [cite: 338, 340]"}
        ]
      }
    }
  },
  "Schedule G - Simulated Rail Switching (模擬鐵路衝擊)": {
    "Longitudinal Shock (縱向衝擊)": {
      "Railcar Coupling Impact": {
        "parameters": {
          "Description": "模擬火車車廂調度時的劇烈縱向撞擊 [cite: 342]",
          "Shock Duration": "40 ± 10 ms for standard draft gear [cite: 344]"
        },
        "tests": [
          {"Assurance Level": "Level I", "Impacts": "2 impacts at 8 mph (3.58 m/s), 1 impact at 6 mph (2.68 m/s) "},
          {"Assurance Level": "Level II", "Impacts": "2 impacts at 6 mph (2.68 m/s), 1 impact at 4 mph (1.79 m/s) "},
          {"Assurance Level": "Level III", "Impacts": "1 impact at 6 mph (2.68 m/s), 2 impacts at 4 mph (1.79 m/s) "}
        ]
      }
    }
  },
  "Schedule H - Environmental Hazard (環境危害)": {
    "Cyclic Exposure (循環暴露)": {
      "Military/Harsh Environment": {
        "parameters": {
          "Description": "模擬軍事分發或嚴苛環境的快速溫濕度變化 [cite: 360]",
          "Water Spray Level I": "4 ± 0.5 in./h (100 ± 10 mm/h) [cite: 363]",
          "Water Spray Level II": "2 ± 0.5 in./h (50 ± 10 mm/h) [cite: 363]"
        },
        "tests": [
          {"Phase": "Hot & Wet", "Condition": "160 ± 5 °F (71 ± 2 °C) with Water Spray, varying durations [cite: 368]"},
          {"Phase": "Cold", "Condition": "-65 ± 5 °F (-54 ± 2 °C), varying durations [cite: 368]"},
          {"Phase": "Requirement", "Condition": "Cyclic sequence repeated on three consecutive days [cite: 368]"}
        ]
      }
    }
  },
  "Schedule I - Low Pressure Hazard (低壓危害)": {
    "High Altitude (高海拔)": {
      "Feeder Aircraft / Mountain Pass": {
        "parameters": {
          "Description": "模擬非加壓機艙或高山運輸的低壓環境 [cite: 374, 375]",
          "Expected Altitude": "4267 m (14,000 ft) if not known precisely [cite: 380]"
        },
        "tests": [
          {"Phase": "Exposure", "Condition": "Maintain equivalent pressure for 60 min [cite: 380]"}
        ]
      }
    }
  },
