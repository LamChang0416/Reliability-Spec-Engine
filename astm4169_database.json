          "Test Type": "Random Vibration (PSD)",
          "Frequency Range": "3 to 200 Hz",
          "Test Duration": "60 min/axis (vertical only for standard; 3-axis for critical items)"
        },
        "tests": [
          {"Freq (Hz)": "3", "PSD (g²/Hz)": "0.001", "Slope": "—"},
          {"Freq (Hz)": "6", "PSD (g²/Hz)": "0.01", "Slope": "+6 dB/oct"},
          {"Freq (Hz)": "20", "PSD (g²/Hz)": "0.01", "Slope": "Flat"},
          {"Freq (Hz)": "200", "PSD (g²/Hz)": "0.0002", "Slope": "-6 dB/oct"},
          {"Freq (Hz)": "Summary", "PSD (g²/Hz)": "Overall 1.12 g rms", "Slope": "Per Figure 11 (D4169-22)"}
        ]
      },
      "Fixed-Displacement Vibration (LTL)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "零擔 (LTL) 固定位移振動測試",
          "Description_EN": "Less-than-truckload (LTL) fixed-displacement vibration",
          "Test Type": "Fixed-displacement sinusoidal",
          "Amplitude": "25.4 mm (1.0 inch) double amplitude",
          "Frequency": "3 Hz",
          "Duration": "At least 30 minutes"
        },
        "tests": [
          {"Phase": "Setup", "Condition": "Mount package on vibration table with free-vertical movement"},
          {"Phase": "Vibration", "Condition": "25.4 mm DA at 3 Hz for 30 minutes"},
          {"Phase": "Post-test", "Condition": "Inspect for damage; perform functional test"}
        ]
      }
    },
    "Shock - Drop": {
      "Handling Drop (Assurance Level I)": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "物流搬運跌落測試 – D4169-22 依重量重新分級 (Assurance Level I)",
          "Description_EN": "Logistics handling drop – D4169-22 revised weight-based heights (AL I)",
          "Assurance Level": "I",
          "Drop Surface": "Concrete or equivalent rigid surface",
          "Number of Drops": "Per Table 10 (D4169-22)"
        },
        "tests": [
          {"Weight (kg)": "< 4.5", "Drop Height (cm)": "91 (36 in)", "Faces/Drops": "All faces, edges, corners"},
          {"Weight (kg)": "4.5–9.1", "Drop Height (cm)": "76 (30 in)", "Faces/Drops": "All faces, edges, corners"},
          {"Weight (kg)": "9.1–18.1", "Drop Height (cm)": "61 (24 in)", "Faces/Drops": "All faces, edges, corners"},
          {"Weight (kg)": "18.1–36.3", "Drop Height (cm)": "46 (18 in)", "Faces/Drops": "6 faces + 4 edges"},
          {"Weight (kg)": "36.3–68.2", "Drop Height (cm)": "30 (12 in)", "Faces/Drops": "6 faces"},
          {"Weight (kg)": "> 68.2", "Drop Height (cm)": "20 (8 in)", "Faces/Drops": "6 faces"}
        ]
      }
    },
    "Compression": {
      "Stack Compression": {
        "parameters": {
          "Standard": "ASTM D4169-22",
          "Description_ZH": "堆疊壓縮測試 – 模擬倉儲或運輸中上方貨物重壓",
          "Description_EN": "Stacking compression – simulates warehouse storage loading from above",
          "Load Calculation": "Based on expected warehouse stacking height and pallet configuration",
          "Typical Load": "Maximum load from lowest item in stack × 1.5 safety factor",
          "Duration": "1 hour"
        },
        "tests": [
          {"Phase": "Load Application", "Condition": "Apply calculated compression load uniformly on top surface"},
          {"Phase": "Dwell", "Condition": "Hold for 1 hour at full load"},
          {"Phase": "Post-test", "Condition": "Inspect for package deformation; verify product functionality"}
        ]
      }
    }
  },
